<!doctype html>
<html loaded lang="{%= page.data.locale || 'en' %}">
<head>
  {%@ "head" %}
</head>
<body class="{{ data.layout }} {{ data.page_class }}">

{%@ Shared::Navbar metadata: site.metadata, resource: resource %}

<main id="main" class="min-h-screen max-w-screen-2xl mx-auto px-4 lg:px-8">
  {%= yield %}
</main>

{%@ "footer", metadata: site.metadata %}
</body>
</html>
